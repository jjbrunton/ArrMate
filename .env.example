# Optional: 32-byte hex key for encrypting API keys at rest
# If omitted, ArrMate generates and persists one automatically on first launch.
# Keep this set temporarily during upgrades if older instance API keys were encrypted with an env-managed key.
# ENCRYPTION_KEY=

# Optional: 32-byte hex key for signing session tokens
# If omitted, ArrMate generates and persists one automatically on first launch.
# Username and password are created during the first-run onboarding flow.
# AUTH_SESSION_SECRET=

# Optional: Path to SQLite database file
# DB_PATH=./data/arrmate.db

# Optional: Log level (trace, debug, info, warn, error, fatal)
# LOG_LEVEL=info
